{
  "name": "obsidian-plugin-template",
  "version": "0.1.0",
  "description": "A template for creating Obsidian plugins with shared CI/CD.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add versions.json manifest.json",
    "test": "vitest run",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin"
  ],
  "author": "firstsun-dev",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "obsidian": "^1.7.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
